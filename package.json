{
  "name": "optical-center",
  "version": "0.2.0-alpha.0",
  "description": "Computes the perceptual optical center of an icon for visually balanced rendering.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./babel": {
      "types": "./dist/babel/index.d.ts",
      "import": "./dist/babel/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "optical-center": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "optical-center",
    "icon",
    "perceptual",
    "centering",
    "svg",
    "ui"
  ],
  "license": "MIT",
  "dependencies": {
    "@babel/types": "^7.29.0",
    "@resvg/resvg-js": "^2.6.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.6.0",
    "typescript": "^5.4.0",
    "vite": "^7.3.2",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@babel/core": "^7.29.0",
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "@babel/core": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  }
}
