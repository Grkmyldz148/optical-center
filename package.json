{
  "name": "optical-center",
  "version": "0.2.0-alpha.1",
  "description": "Computes the perceptual optical center of an icon for visually balanced rendering.",
  "homepage": "https://opticalcenter.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Grkmyldz148/optical-center.git"
  },
  "bugs": "https://github.com/Grkmyldz148/optical-center/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./babel": {
      "types": "./dist/babel/index.d.ts",
      "import": "./dist/babel/index.js"
    },
    "./babel/jsx-runtime-augment": {
      "types": "./dist/babel/jsx-runtime-augment.d.ts"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    },
    "./astro": {
      "types": "./dist/astro/index.d.ts",
      "import": "./dist/astro/index.js"
    },
    "./postcss": {
      "types": "./dist/postcss/index.d.ts",
      "import": "./dist/postcss/index.js"
    },
    "./tailwind": {
      "types": "./dist/tailwind/index.d.ts",
      "import": "./dist/tailwind/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js",
      "default": "./dist/next/index.js"
    },
    "./next/loader": {
      "types": "./dist/next/loader.d.ts",
      "import": "./dist/next/loader.js",
      "default": "./dist/next/loader.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "optical-center": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "cli": "node dist/cli/index.js",
    "dev:cli": "npm run build && node dist/cli/index.js",
    "dev:playground": "npm run dev --workspace apps/playground",
    "dev:site": "npm run dev --workspace apps/site",
    "build:playground": "npm run build --workspace apps/playground",
    "build:site": "npm run build --workspace apps/site",
    "preview:playground": "npm run preview --workspace apps/playground",
    "preview:site": "npm run preview --workspace apps/site",
    "check:site": "npm run check --workspace apps/site"
  },
  "workspaces": [
    "examples/*",
    "apps/playground",
    "apps/site"
  ],
  "keywords": [
    "optical-center",
    "icon",
    "perceptual",
    "centering",
    "svg",
    "ui"
  ],
  "license": "MIT",
  "dependencies": {
    "@babel/types": "^7.29.0",
    "@resvg/resvg-js": "^2.6.0",
    "chalk": "^5.6.2",
    "write-file-atomic": "^7.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/write-file-atomic": "^4.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "astro": "^5.18.1",
    "postcss": "^8.4.0",
    "typescript": "^5.4.0",
    "vite": "^7.3.2",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@babel/core": "^7.29.0",
    "astro": ">=4",
    "next": ">=15",
    "postcss": "^8.5.13",
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "@babel/core": {
      "optional": true
    },
    "astro": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "postcss": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  }
}
